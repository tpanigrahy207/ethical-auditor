{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/scan.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/scan",
      "destination": "/api/scan"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
